      "version": 51,
      "versionNonce": 1803918247,
      "isDeleted": false,
      "text": "1) Functional Requirements\nUsers: Product/App Teams • Operators/On-call • Platform/Admin\nPer user: configure • observe • control\nExplicit v1 scope stated before architecture",
      "fontSize": 14,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 14,
      "containerId": null,
      "originalText": "1) Functional Requirements\nUsers: Product/App Teams • Operators/On-call • Platform/Admin\nPer user: configure • observe • control\nExplicit v1 scope stated before architecture",
