    {
      "id": "sr2",
      "type": "rectangle",
      "x": 27.160661287018115,
      "y": 428.83775871643223,
      "width": 943.576004943849,
      "height": 374.4549921690939,
      "angle": 0,
      "strokeColor": "#000000",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
