    {
      "id": "aEEieSb9DQRrExBx5lwf3",
      "type": "text",
      "x": -1618.8366804820585,
      "y": -2969.7713770220394,
      "width": 8529.569101023937,
      "height": 725,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b73",
