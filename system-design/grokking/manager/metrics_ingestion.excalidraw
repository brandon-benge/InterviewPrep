    {
      "id": "sK3h3sJuTCwnFcGMJSmVn",
      "type": "text",
      "x": -1097.518938271402,
      "y": -1368.2508984310496,
      "width": 2112.1981032262674,
      "height": 3661.626127623683,
      "angle": 0,
